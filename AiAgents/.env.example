# ================================
# LLM Providers
# ================================
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here
GROQ_API_KEY=gsk_your-groq-key-here
GOOGLE_API_KEY=your-google-gemini-key-here

# ================================
# Default LLM Config
# ================================
DEFAULT_LLM_PROVIDER=groq
DEFAULT_LLM_MODEL=qwen-qwq-32b
DEFAULT_TEMPERATURE=0.0
DEFAULT_MAX_TOKENS=4096

# ================================
# Observability
# ================================
LANGSMITH_API_KEY=ls__your-langsmith-key-here
LANGSMITH_TRACING=true
LANGSMITH_PROJECT=ai-engineer

LANGFUSE_PUBLIC_KEY=pk-lf-your-public-key
LANGFUSE_SECRET_KEY=sk-lf-your-secret-key
LANGFUSE_HOST=https://cloud.langfuse.com

# ================================
# Memory & Storage
# ================================
CHECKPOINT_DB_URL=sqlite:///./data/checkpoints.db
# For production: postgresql+psycopg://user:pass@localhost:5432/ai_agents

# ================================
# GenAISystem API
# ================================
GENAI_SYSTEM_URL=http://localhost:8001

# ================================
# MCPServer
# ================================
MCP_SERVER_URL=http://localhost:8002
MCP_API_KEY=your-mcp-api-key-here

# ================================
# Long-term Vector Memory
# ================================
VECTOR_MEMORY_PROVIDER=faiss
QDRANT_URL=http://localhost:6333
