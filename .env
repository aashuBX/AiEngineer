# ==============================================================
# AiEngineer — Unified Environment File
# Copy this to .env and fill in your real values.
# ==============================================================

# ==============================================================
# LLM Provider — Groq (free tier)
# ==============================================================
DEFAULT_LLM_PROVIDER=groq
DEFAULT_LLM_MODEL=llama3-70b-8192
DEFAULT_TEMPERATURE=0.0
DEFAULT_MAX_TOKENS=4096
GROQ_API_KEY=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

# Also set for GenAISystem (it reads its own env vars)
LLM_PROVIDER=groq
LLM_MODEL=llama3-70b-8192

# ==============================================================
# Embeddings — HuggingFace (no API key needed, runs locally)
# ==============================================================
EMBEDDING_PROVIDER=sentence-transformers
EMBEDDING_MODEL=all-MiniLM-L6-v2

# ==============================================================
# Vector DB — Pinecone (for RAG Agent)
# ==============================================================
PINECONE_API_KEY=pcsk_6J9Lig_8QnD9uj1fy82naL6h1tqeUcS3ex1yJJLUi38NqHsdsxJLwv489A1HRcnHNPpud7
PINECONE_ENVIRONMENT=gcp-starter
PINECONE_INDEX_NAME=aiagent-rag
VECTOR_STORE_PROVIDER=pinecone

# ==============================================================
# Knowledge Graph — Neo4j (for GraphRAG Agent)
# ==============================================================
NEO4J_URI=bolt://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=my-secret-password

# ==============================================================
# CRM Database — MySQL
# ==============================================================
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_USER=crm_user
MYSQL_PASSWORD=crm_password
MYSQL_DATABASE=crm_db
DB_TOOL_CONNECTION_STRING=mysql+pymysql://crm_user:crm_password@mysql:3306/crm_db

# ==============================================================
# MCPServer
# ==============================================================
MCP_API_KEY=dev-key-12345
MCP_SERVER_URL=http://mcp_server:8002

# ==============================================================
# GenAISystem API
# ==============================================================
GENAI_SYSTEM_URL=http://genai_system:8001

# ==============================================================
# AiAgents API
# ==============================================================
AGENTS_API_PORT=8000

# ==============================================================
# Observability (optional, leave blank to disable)
# ==============================================================
LANGSMITH_API_KEY=
LANGSMITH_TRACING=false
LANGSMITH_PROJECT=ai-engineer

# ==============================================================
# File System Tool (MCPServer)
# ==============================================================
ALLOWED_FS_PATHS=/app/data/shared
